healthy_food_bank_flutter/ios/Runner/GeneratedPluginRegistrant.*

# Flutter Web
healthy_food_bank_flutter/web/flutter_service_worker.js

# Flutter generated
healthy_food_bank_flutter/lib/generated_plugin_registrant.dart

