# ============================================================
# Healthy Food Bank Application - .gitignore
# Monorepo: Spring Boot Microservices + Angular + Flutter
# ============================================================

# ────────────────────────────────────────────────────────────
# JAVA / SPRING BOOT (user-service, product-service, order-service)
# ────────────────────────────────────────────────────────────
**/target/
*.class
*.jar
*.war
*.ear

# Maven wrapper (keep mvnw and mvnw.cmd, ignore downloaded jars)
.mvn/wrapper/maven-wrapper.jar

# Logs
*.log
**/hs_err_pid*.log
**/replay_pid*.log

# JVM crash dumps
hs_err_pid*
replay_pid*

# ────────────────────────────────────────────────────────────
# ANGULAR (frontend-angular)
# ────────────────────────────────────────────────────────────
**/node_modules/
frontend-angular/dist/
frontend-angular/.angular/
frontend-angular/.cache/

# ────────────────────────────────────────────────────────────
# FLUTTER (healthy_food_bank_flutter)
# ────────────────────────────────────────────────────────────
healthy_food_bank_flutter/build/
healthy_food_bank_flutter/.dart_tool/
healthy_food_bank_flutter/.flutter-plugins
healthy_food_bank_flutter/.flutter-plugins-dependencies
healthy_food_bank_flutter/.packages
healthy_food_bank_flutter/.pub-cache/
healthy_food_bank_flutter/.pub/

# Flutter Android
healthy_food_bank_flutter/android/local.properties
healthy_food_bank_flutter/android/.gradle/
healthy_food_bank_flutter/android/app/build/
healthy_food_bank_flutter/android/build/
healthy_food_bank_flutter/android/captures/
healthy_food_bank_flutter/android/*.iml

# Flutter iOS
healthy_food_bank_flutter/ios/Pods/
healthy_food_bank_flutter/ios/.symlinks/
healthy_food_bank_flutter/ios/Flutter/Flutter.framework
healthy_food_bank_flutter/ios/Flutter/Flutter.podspec
healthy_food_bank_flutter/ios/Flutter/Generated.xcconfig
